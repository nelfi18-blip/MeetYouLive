# Shared server-to-server secret for /api/auth/google-session.
# Must be set to the SAME value in both Render (backend) and Vercel (frontend).
# Example: INTERNAL_API_SECRET=meetyoulive-secret
INTERNAL_API_SECRET=

# Admin seed – used by createAdminIfNotExists on server start and by npm run seed:admin
ADMIN_NAME=meetyoulive
ADMIN_EMAIL=admin@meetyoulive.net
ADMIN_PASSWORD=

# Email (SMTP) — used for registration verification codes.
# Leave blank to print verification codes to the server console (development mode).
# Works with any SMTP provider (Gmail, SendGrid SMTP, Mailgun SMTP, etc.)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=MeetYouLive <noreply@meetyoulive.net>
