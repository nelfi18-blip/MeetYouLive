NEXT_PUBLIC_API_URL=https://api.meetyoulive.net
NEXT_PUBLIC_AGORA_APP_ID=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://www.meetyoulive.net
# Shared server-to-server secret for /api/auth/google-session.
# Must be set to the SAME value in both Vercel (frontend) and Render (backend).
# Example: INTERNAL_API_SECRET=meetyoulive-secret
INTERNAL_API_SECRET=

# Firebase push notifications (FCM)
# Get these values from your Firebase project settings → General → Your apps → Web app
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# VAPID key from Firebase → Cloud Messaging → Web Push certificates
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# Analytics and Tracking (optional but recommended for launch)
# Google Analytics 4 - Get from https://analytics.google.com
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Facebook Pixel - Get from https://business.facebook.com
# Format: numeric ID
NEXT_PUBLIC_FACEBOOK_PIXEL_ID=

# TikTok Pixel (optional) - Get from TikTok Ads Manager
NEXT_PUBLIC_TIKTOK_PIXEL_ID=
